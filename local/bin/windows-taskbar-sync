#!/usr/bin/env python3

import fcntl
import json
import os
import re
import signal
import subprocess
import time
from pathlib import Path

HOME = Path.home()
STATE_DIR = HOME / ".local/state/windows11"
HIDDEN = STATE_DIR / "taskbar-hidden"
LOCK = STATE_DIR / "taskbar-sync.lock"
BAR_CONFIG = HOME / ".config/waybar/windows11/config.jsonc"
BAR_COMMAND = HOME / ".local/bin/windows-waybar"
BAR_PATTERN = rf"^waybar .*--config {re.escape(str(BAR_CONFIG))}"


def bar_pids():
    result = subprocess.run(
        ["pgrep", "-f", BAR_PATTERN],
        text=True,
        capture_output=True,
        check=False,
    )
    return [int(pid) for pid in result.stdout.split() if pid.isdigit()]


def active_is_fullscreen():
    result = subprocess.run(
        ["hyprctl", "activewindow", "-j"],
        text=True,
        capture_output=True,
        check=False,
    )
    try:
        window = json.loads(result.stdout)
    except json.JSONDecodeError:
        return False
    return int(window.get("fullscreen", window.get("fullscreenClient", 0)) or 0) != 0


def start_bar():
    subprocess.Popen(
        [str(BAR_COMMAND)],
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    for _ in range(20):
        pids = bar_pids()
        if pids:
            return pids
        time.sleep(0.05)
    return []


def main():
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with LOCK.open("w") as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)

        pids = bar_pids()
        if len(pids) > 1:
            for pid in pids[1:]:
                try:
                    os.kill(pid, signal.SIGTERM)
                except ProcessLookupError:
                    pass
            pids = pids[:1]

        if not pids:
            HIDDEN.unlink(missing_ok=True)
            pids = start_bar()

        should_hide = active_is_fullscreen()
        is_hidden = HIDDEN.exists()

        if pids and should_hide != is_hidden:
            for pid in pids:
                try:
                    os.kill(pid, signal.SIGUSR1)
                except ProcessLookupError:
                    pass

            if should_hide:
                HIDDEN.touch()
            else:
                HIDDEN.unlink(missing_ok=True)


if __name__ == "__main__":
    main()
