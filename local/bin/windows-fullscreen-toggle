#!/usr/bin/env bash

set -euo pipefail

window="$(hyprctl activewindow -j)"
address="$(jq -r '.address // empty' <<<"$window")"

[[ -n "$address" && "$address" != "0x0" ]] || exit 0

fullscreen="$(jq -r '.fullscreen // .fullscreenClient // 0' <<<"$window")"

if [[ "$fullscreen" == "0" ]]; then
    hyprctl dispatch fullscreenstate 2 2 >/dev/null
else
    hyprctl dispatch fullscreenstate 0 0 >/dev/null
fi

sleep 0.05
exec "$HOME/.local/bin/windows-taskbar-sync"
