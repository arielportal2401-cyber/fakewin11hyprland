#!/usr/bin/env python3
import json, urllib.parse, urllib.request
from pathlib import Path

home = Path.home()
location = json.loads((home / ".config/windows11/location.json").read_text())
cache = home / ".cache/windows11-weather.json"
params = urllib.parse.urlencode({"latitude": location["latitude"], "longitude": location["longitude"], "current": "temperature_2m,apparent_temperature,weather_code,is_day", "timezone": location["timezone"]})
try:
    with urllib.request.urlopen("https://api.open-meteo.com/v1/forecast?" + params, timeout=6) as response: data = json.load(response)
    cache.parent.mkdir(parents=True, exist_ok=True); cache.write_text(json.dumps(data))
except Exception:
    data = json.loads(cache.read_text()) if cache.exists() else {}
current = data.get("current", {}); temperature = round(current.get("temperature_2m", 0)); feels = round(current.get("apparent_temperature", temperature)); code = current.get("weather_code", -1); day = current.get("is_day", 1) == 1
if code == 0: icon, condition, style = ("☀" if day else "☾"), "Clear", "clear"
elif code in (1, 2, 3): icon, condition, style = "☁", "Cloudy", "cloudy"
elif code in (45, 48): icon, condition, style = "≋", "Fog", "fog"
elif code in (51,53,55,56,57,61,63,65,66,67,80,81,82): icon, condition, style = "☂", "Rain", "rain"
elif code in (71,73,75,77,85,86): icon, condition, style = "❄", "Snow", "snow"
elif code in (95,96,99): icon, condition, style = "ϟ", "Thunderstorm", "storm"
else: icon, condition, style = "•", "Weather unavailable", "unknown"
print(json.dumps({"text": f"{icon}  {temperature}°C", "tooltip": f"{location['name']} — {condition}\nFeels like {feels}°C", "class": style}))
