#!/usr/bin/env bash

set -euo pipefail

# The shell, Quickshell, and desktop files can have different PATH values.
# Always select one real Flatpak binary and keep every Windows-shell launcher
# on the same code path.
for candidate in \
    "$HOME/.nix-profile/bin/flatpak" \
    /usr/local/bin/flatpak \
    /usr/bin/flatpak \
    /bin/flatpak; do
    if [[ -x "$candidate" && "$candidate" != "$0" ]]; then
        flatpak_bin="$candidate"
        break
    fi
done

if [[ -z "${flatpak_bin:-}" ]]; then
    hyprctl notify 3 3500 "rgb(ff9999)" "Flatpak is not installed" >/dev/null 2>&1 || true
    exit 127
fi

exec "$flatpak_bin" "$@"
