#!/usr/bin/env python3

import fcntl
import os
import socket
import subprocess
import time
from pathlib import Path

HOME = Path.home()
STATE_DIR = HOME / ".local/state/windows11"
WATCH_LOCK = STATE_DIR / "taskbar-watch.lock"
SYNC = HOME / ".local/bin/windows-taskbar-sync"
EVENTS = {
    "workspace",
    "workspacev2",
    "focusedmon",
    "activewindow",
    "activewindowv2",
    "fullscreen",
    "openwindow",
    "closewindow",
    "movewindow",
}


def sync_bar():
    subprocess.run([str(SYNC)], check=False)


def event_socket():
    runtime = Path(os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}"))
    signature = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE", "")
    return runtime / "hypr" / signature / ".socket2.sock"


def watch():
    path = event_socket()
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as connection:
        connection.connect(str(path))
        sync_bar()
        pending = b""
        while True:
            chunk = connection.recv(8192)
            if not chunk:
                return
            pending += chunk
            lines = pending.split(b"\n")
            pending = lines.pop()
            for line in lines:
                event = line.partition(b">>")[0].decode(errors="replace")
                if event in EVENTS:
                    sync_bar()


def main():
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with WATCH_LOCK.open("w") as lock:
        try:
            fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return

        while True:
            try:
                watch()
            except (FileNotFoundError, ConnectionError, OSError):
                pass
            time.sleep(0.5)


if __name__ == "__main__":
    main()
